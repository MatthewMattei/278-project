# Copy to .env.local — never commit real secrets
# Supabase (Dashboard → Settings → API). Required on Vercel for middleware + browser — deploy both below.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Map tiles (Leaflet) — optional; defaults to free Carto OSM basemap (no API key)
# NEXT_PUBLIC_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png
# NEXT_PUBLIC_MAP_TILE_SUBDOMAINS=abcd
# NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=&copy; OpenStreetMap &copy; CARTO

# Vercel Cron: Authorization: Bearer <CRON_SECRET> (Hobby: daily max — see vercel.json)
CRON_SECRET=random_long_string_for_cron_header
