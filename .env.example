# Copy to .env.local — never commit real secrets
# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Maps JS API (browser; restrict by HTTP referrer)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_browser_key

# Optional: Geocoding on server (Route Handlers); can match browser key with both restrictions or use a separate key
GOOGLE_MAPS_API_KEY=your_server_geocoding_key

# Vercel Cron: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=random_long_string_for_cron_header
